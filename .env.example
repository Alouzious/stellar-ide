# ============================================
# StellarIDE — Environment Variables Template
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ============================================

# ── Database ─────────────────────────────────
DATABASE_URL=postgres://stellar_user:stellar_pass@localhost:5432/stellar_ide
POSTGRES_DB=stellar_ide
POSTGRES_USER=stellar_user
POSTGRES_PASSWORD=stellar_pass

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── Auth ─────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_in_production
JWT_EXPIRY_HOURS=24

# ── GitHub OAuth ─────────────────────────────
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_secret
GITHUB_REDIRECT_URL=http://localhost:3000/auth/github/callback

# ── Sandbox ──────────────────────────────────
SANDBOX_IMAGE=wasm_sandbox
MAX_SANDBOXES=4
SANDBOX_CPU_LIMIT=1
SANDBOX_MEMORY_LIMIT=1g
SANDBOX_TIMEOUT_SECS=120

# ── Server ───────────────────────────────────
PORT=8080
RUST_LOG=info

# ── Frontend (Vite) ──────────────────────────
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080
VITE_STELLAR_NETWORK=TESTNET