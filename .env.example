# ============================================
# StellarIDE — Environment Variables Template
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ============================================

# ── Database ─────────────────────────────────
DATABASE_URL=postgres://stellar_user:stellar_pass@localhost:5432/stellar_ide
POSTGRES_DB=stellar_ide
POSTGRES_USER=stellar_user
POSTGRES_PASSWORD=stellar_pass

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── Auth ─────────────────────────────────────
JWT_SECRET=g8QaO8rxhC5wr7AhaixnOUs/u62Its9UgFlIOIAvfGde7neUTL8Ma1H8Oh4BC+0O
JWT_EXPIRY_HOURS=24

# ── GitHub OAuth ─────────────────────────────
GITHUB_CLIENT_ID=Ov23liPnudhSbvpTbLYs
GITHUB_CLIENT_SECRET=44e7b01edf03408058225ba2e3872351d05697c9
GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/github/callback

# ── Sandbox ──────────────────────────────────
SANDBOX_IMAGE=asm_sandbox
MAX_SANDBOXES=4
SANDBOX_CPU_LIMIT=1
SANDBOX_MEMORY_LIMIT=1g
SANDBOX_TIMEOUT_SECS=120


# ── Server ───────────────────────────────────
PORT=8080
RUST_LOG=info

# ── Frontend (Vite) ──────────────────────────
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080
VITE_STELLAR_NETWORK=TESTNET